listen:
  host: 127.0.0.1
  port: 3000

logLevel: info
webform:
  enabled: true
  # set false to disable route:
  # POST /v1/webhooks/agents/:agentId/webform/:formId

WEBFORM_ALLOWED_ORIGINS:
  - https://tashi.namche.ai
  # add any other origins that host webforms

agents:
  tashi:
    url: https://tashi.silverside-mermaid.ts.net
    openclawHooksToken: Bearer <OPENCLAW_HOOKS_TOKEN_TASHI>

apps:
  krisp:
    enabled: true
    incomingAuthorization: Bearer <KRISP_AUTHORIZATION>
    targetAgent: tashi
    # OpenClaw hook parameters (hardwired in code, documented here for reference):
    # agentId: main              — which OpenClaw agent session to target
    # sessionKey: hook:notetaker:krisp — routes into the Krisp notetaker hook session
    # wakeMode: next-heartbeat   — processed at the next heartbeat, not urgently
    # deliver: false             — queued silently; no immediate notification pushed

  # github is optional — omit to disable the route
  # Webhook URL format:
  #   /v1/webhooks/apps/github/<owner>/<repo>
  github:
    enabled: true
    targetAgent: tashi
    webhookSecret: <GITHUB_WEBHOOK_SECRET>
    sessionKey: agent:main:discord:channel:<DISCORD_CHANNEL_ID>

  # webforms: handled generically via POST /v1/webhooks/agents/:agentId/webform/:formId
  # No config needed — any formId is accepted and forwarded as webform:<formId>
  # The receiving agent's webform.md playbook routes by formId.
  # Example URLs:
  #   /v1/webhooks/agents/tashi/webform/complaint
  #   /v1/webhooks/agents/tashi/webform/contact

  # gmail is optional — omit to disable the route
  gmail:
    enabled: true  # set false to disable Gmail proxy route without removing this block
    oidcEmail: <SERVICE_ACCOUNT>@<PROJECT>.iam.gserviceaccount.com  # expected GCP SA in OIDC JWT
    targetAgent: tashi
    forwardUrl: https://tashi.silverside-mermaid.ts.net/gmail-pubsub?token=<GOG_SERVE_TOKEN>
