listen:
  host: 127.0.0.1
  port: 3000

logLevel: info
webform:
  enabled: true
  # set false to disable route:
  # POST /v1/webhooks/agents/:agentId/webform/:formId

WEBFORM_ALLOWED_ORIGINS:
  - https://tashi.namche.ai
  # add any other origins that host webforms

agents:
  tashi:
    url: https://tashi.silverside-mermaid.ts.net
    openclawHooksToken: Bearer <OPENCLAW_HOOKS_TOKEN_TASHI>
  pema:
    url: https://<pema-tailscale-host>
    openclawHooksToken: Bearer <OPENCLAW_HOOKS_TOKEN_PEMA>

apps:
  krisp:
    enabled: true
    # Required: auth per agentId in route /v1/webhooks/agents/:agentId/notetaker/krisp
    agents:
      tashi:
        incomingAuthorization: Bearer <KRISP_AUTHORIZATION_TASHI>
      pema:
        incomingAuthorization: Bearer <KRISP_AUTHORIZATION_PEMA>
    # OpenClaw hook parameters (hardwired in code, documented here for reference):
    # sessionKey: hook:notetaker:krisp — routes into the Krisp notetaker hook session
    # deliver: false             — queued silently; no immediate notification pushed

  # github is optional — omit to disable the route
  # Webhook URL format:
  #   /v1/webhooks/apps/github/<owner>/<repo>
  github:
    enabled: true
    targetAgent: tashi
    webhookSecret: <GITHUB_WEBHOOK_SECRET>
    sessionKey: agent:main:discord:channel:<DISCORD_CHANNEL_ID>

  # webforms: handled generically via POST /v1/webhooks/agents/:agentId/webform/:formId
  # No config needed — any formId is accepted and forwarded as webform:<formId>
  # The receiving agent's webform.md playbook routes by formId.
  # Example URLs:
  #   /v1/webhooks/agents/tashi/webform/complaint
  #   /v1/webhooks/agents/tashi/webform/contact

  # gmail is optional — omit to disable the route
  # subscriptions maps Gmail subscription emails. Each key's local part must
  # match a configured agent shortname, for example tashi@namche.ai -> agents.tashi.
  # The oidcEmail is the GCP service account expected in the Pub/Sub OIDC JWT.
  # The proxy derives http://<agent host>:<forwardPort>/gmail-pubsub from the
  # matching agents.<agentId>.url and forwards the same Authorization header.
  # forwardPort is optional and defaults to 8788.
  gmail:
    subscriptions:
      tashi@namche.ai:
        oidcEmail: pubsub-push@<PROJECT>.iam.gserviceaccount.com
        # forwardPort: 8788  # optional, default shown for clarity
      pema@namche.ai:
        oidcEmail: pubsub-push@<PROJECT>.iam.gserviceaccount.com
        # forwardPort: 8788
      # nima@namche.ai:
      #   oidcEmail: pubsub-push@<PROJECT>.iam.gserviceaccount.com
      #   forwardPort: 8788
